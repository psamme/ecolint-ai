{
  "name": "trimference",
  "version": "0.3.0",
  "description": "Local static analysis for LLM application efficiency safeguards.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/psamme/trimference#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/psamme/trimference.git"
  },
  "bugs": {
    "url": "https://github.com/psamme/trimference/issues"
  },
  "keywords": [
    "ai",
    "llm",
    "cli",
    "linter",
    "static-analysis",
    "developer-tools",
    "llmops",
    "cost-optimization",
    "sarif",
    "code-quality",
    "github-actions",
    "typescript"
  ],
  "bin": {
    "trimference": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "action.yml",
    "README.md",
    "DEMO.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "BENCHMARK.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "scan:example": "tsx src/cli.ts scan --path examples/wasteful-ai-app",
    "scan:self": "tsx src/cli.ts scan --path src --summary",
    "verify": "npm run build && npm test && node dist/cli.js scan --path src --summary --fail-on low && node dist/cli.js scan --path examples/cleaner-ai-app --summary --fail-on low",
    "prepublishOnly": "npm run verify"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
